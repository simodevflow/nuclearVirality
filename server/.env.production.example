# ☢️ NUCLEARVIRALITY - PRODUCTION ENVIRONMENT VARIABLES
# Copy this to .env and fill in your actual values

# ============================================
# EMAIL CONFIGURATION (REQUIRED)
# ============================================

# For cPanel Email (Recommended for cPanel hosting)
EMAIL_HOST=mail.yourdomain.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=contact@yourdomain.com
EMAIL_PASS=your-cpanel-email-password

# Alternative: Gmail (requires App Password)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-16-char-app-password

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port (cPanel assigns this automatically, usually 3000-3999)
PORT=3000

# Environment
NODE_ENV=production

# Your domain (for email templates)
DOMAIN=yourdomain.com

# Allowed origins for CORS (comma-separated, no spaces)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# BOOKING/CALENDAR
# ============================================

# Calendly or booking link
CALENDLY_LINK=https://calendly.com/your-link

# ============================================
# OPTIONAL: ANALYTICS & TRACKING
# ============================================

# Google Analytics ID (optional)
# GA_ID=G-XXXXXXXXXX

# Meta Pixel ID (optional)
# META_PIXEL_ID=123456789

# ============================================
# SETUP INSTRUCTIONS
# ============================================

# 1. Copy this file to .env in the server/ directory
# 2. Fill in all REQUIRED fields above
# 3. For cPanel email:
#    - Go to cPanel → Email Accounts
#    - Create: contact@yourdomain.com
#    - Use that password in EMAIL_PASS
# 4. Update DOMAIN to your actual domain
# 5. Add your Calendly link
# 6. Save the file
# 7. NEVER commit .env to version control!

# ============================================
# CPANEL EMAIL SETUP HELP
# ============================================

# If using cPanel email, your settings should look like:
# EMAIL_HOST=mail.yourdomain.com (or localhost if on same server)
# EMAIL_PORT=465 (SSL) or 587 (TLS)
# EMAIL_SECURE=true (for 465) or false (for 587)
# EMAIL_USER=contact@yourdomain.com (full email address)
# EMAIL_PASS=the-password-you-set-in-cpanel

# To create cPanel email:
# 1. Login to cPanel
# 2. Email → Email Accounts
# 3. Click "Create"
# 4. Username: contact (or any name)
# 5. Domain: yourdomain.com
# 6. Password: Set a strong password
# 7. Use these credentials above

# ============================================
# SECURITY NOTES
# ============================================

# - Keep this file secret! Add to .gitignore
# - Use strong passwords (16+ characters)
# - Different passwords for dev vs production
# - Rotate passwords quarterly
# - Never share .env in screenshots or support tickets
